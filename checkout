<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إتمام الطلب | SHADOWLACE</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&family=Oswald:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <nav>
        <div class="logo">SHADOWLACE</div>
        <ul class="nav-links">
            <li><a href="index.html">الرئيسية</a></li>
            <li><a href="shop.html">المتجر</a></li>
        </ul>
    </nav>

    <main class="checkout-container">
        <h1 class="section-title">إتمام الطلب</h1>
        
        <div class="order-summary" id="order-summary">
            <h3>ملخص السلة</h3>
            <div id="cart-items-list">
                <!-- Items will be injected here -->
            </div>
            <div class="summary-item total">
                <span>الإجمالي:</span>
                <span id="total-price">0 د.ج</span>
            </div>
        </div>

        <form class="checkout-form" id="orderForm">
            <h3>معلومات التوصيل</h3>
            <div class="form-group">
                <label for="name">الاسم الكامل</label>
                <input type="text" id="name" required placeholder="أدخل اسمك الكامل">
            </div>
            <div class="form-group">
                <label for="phone">رقم الهاتف</label>
                <input type="tel" id="phone" required placeholder="0XXXXXXXXX">
            </div>
            <div class="form-group">
                <label for="address">العنوان الكامل</label>
                <input type="text" id="address" required placeholder="الولاية، البلدية، الشارع">
            </div>
            <div class="form-group">
                <label for="shipping">طريقة التوصيل</label>
                <select id="shipping">
                    <option value="office">توصيل للمكتب (400 د.ج)</option>
                    <option value="home">توصيل للمنزل (700 د.ج)</option>
                </select>
            </div>
            <button type="submit" class="btn-primary" style="width: 100%;">تأكيد الطلب</button>
        </form>
    </main>

    <footer>
        <p>&copy; 2026 SHADOWLACE. جميع الحقوق محفوظة.</p>
    </footer>

    <script src="script.js"></script>
    <script>
        // Specific logic for checkout page
        window.onload = function() {
            displayCart();
        };

        document.getElementById('orderForm').onsubmit = function(e) {
            e.preventDefault();
            alert('شكراً لطلبك! سنتصل بك قريباً لتأكيد الطلب.');
            localStorage.removeItem('cart');
            window.location.href = 'index.html';
        };
    </script>
</body>
</html>
